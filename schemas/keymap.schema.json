{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "keydeck/keymap.schema.json",
  "title": "KeyDeck Keymap",
  "description": "分割レイヤーキーボードのキーマップ（設計書D3/D4/D10）。ロード時にHubが検証し、違反はLOAD_SCHEMA_INVALID＋causeで起動拒否。",
  "type": "object",
  "required": ["keymapId", "halves", "layers"],
  "additionalProperties": false,
  "properties": {
    "keymapId": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "halves": {
      "type": "object",
      "required": ["left", "right"],
      "additionalProperties": false,
      "properties": {
        "left":  { "$ref": "#/$defs/half" },
        "right": { "$ref": "#/$defs/half" }
      }
    },
    "layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "keys"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "integer", "minimum": 0, "maximum": 15 },
          "keys": {
            "type": "object",
            "additionalProperties": { "$ref": "#/$defs/keydef" }
          }
        }
      }
    }
  },
  "$defs": {
    "half": {
      "type": "object",
      "required": ["rows"],
      "additionalProperties": false,
      "properties": {
        "rows": {
          "type": "array", "minItems": 1,
          "items": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^[LR][0-9]{2}$" } }
        }
      }
    },
    "keydef": {
      "type": "object",
      "required": ["label", "action"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string" },
        "action": { "$ref": "#/$defs/action" }
      }
    },
    "action": {
      "description": "D4のアクション型。vk名の辞書検証はスキーマではなくproto-keymap側で行う（LOAD_VK_UNKNOWN）。",
      "oneOf": [
        { "type": "object", "required": ["t", "vk"],    "additionalProperties": false, "properties": { "t": { "const": "key" },   "vk": { "type": "string" } } },
        { "type": "object", "required": ["t", "keys"],  "additionalProperties": false, "properties": { "t": { "const": "chord" }, "keys": { "type": "array", "minItems": 2, "items": { "type": "string" } } } },
        { "type": "object", "required": ["t", "layer"], "additionalProperties": false, "properties": { "t": { "const": "mo" },    "layer": { "type": "integer", "minimum": 1, "maximum": 15 } } },
        { "type": "object", "required": ["t", "layer"], "additionalProperties": false, "properties": { "t": { "const": "tg" },    "layer": { "type": "integer", "minimum": 1, "maximum": 15 } } },
        { "type": "object", "required": ["t"],          "additionalProperties": false, "properties": { "t": { "const": "trans" } } },
        { "type": "object", "required": ["t"],          "additionalProperties": false, "properties": { "t": { "const": "none" } } },
        { "type": "object", "required": ["t", "id"],    "additionalProperties": false, "properties": { "t": { "const": "keymap.switch" }, "id": { "type": "string", "minLength": 1 } } },
        { "type": "object", "required": ["t"],          "additionalProperties": false, "properties": { "t": { "const": "keymap.reset" } } }
      ]
    }
  }
}
