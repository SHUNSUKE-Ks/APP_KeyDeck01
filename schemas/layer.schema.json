{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "keydeck/layer.schema.json",
  "title": "KeyDeck Layer (v0.3 D13)",
  "description": "1レイヤー=1ファイル。keymapマニフェスト(layerFiles)から参照され、Export=/api/keymap/{id}/layer/{n}/export、Import=keymaps/layers/へ配置＋再起動。keysの形はkeymap.schema.jsonの$defs/keydefと同一に保つこと。",
  "type": "object",
  "required": ["layer", "keys"],
  "additionalProperties": false,
  "properties": {
    "layer": { "type": "integer", "minimum": 0, "maximum": 15 },
    "description": { "type": "string" },
    "keys": {
      "type": "object",
      "propertyNames": { "pattern": "^[A-Z][0-9]{2,3}$" },
      "additionalProperties": { "$ref": "keydeck/keymap.schema.json#/$defs/keydef" }
    }
  }
}
